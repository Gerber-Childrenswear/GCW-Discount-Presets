**/*.wasm

# Exception: keep the compiled Shopify Function WASM (built by CI)
# Must un-ignore each directory level for git to traverse into target/
!extensions/gcw-discount-function/target/
!extensions/gcw-discount-function/target/wasm32-unknown-unknown/
!extensions/gcw-discount-function/target/wasm32-unknown-unknown/release/
!extensions/gcw-discount-function/target/wasm32-unknown-unknown/release/gcw_discount_function.wasm

!extensions/gcw-shipping-function/target/
!extensions/gcw-shipping-function/target/wasm32-unknown-unknown/
!extensions/gcw-shipping-function/target/wasm32-unknown-unknown/release/
!extensions/gcw-shipping-function/target/wasm32-unknown-unknown/release/gcw_shipping_function.wasm

!extensions/gcw-tiered-discount/target/
!extensions/gcw-tiered-discount/target/wasm32-unknown-unknown/
!extensions/gcw-tiered-discount/target/wasm32-unknown-unknown/release/
!extensions/gcw-tiered-discount/target/wasm32-unknown-unknown/release/gcw_tiered_discount.wasm

!extensions/gcw-bxgy-discount/target/
!extensions/gcw-bxgy-discount/target/wasm32-unknown-unknown/
!extensions/gcw-bxgy-discount/target/wasm32-unknown-unknown/release/
!extensions/gcw-bxgy-discount/target/wasm32-unknown-unknown/release/gcw_bxgy_discount.wasm

# Re-ignore non-WASM build artifacts inside un-ignored target directories
extensions/*/target/.rustc_info.json
extensions/*/target/release/
extensions/*/target/wasm32-unknown-unknown/release/.cargo-lock
