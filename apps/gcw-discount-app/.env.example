SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_APP_SCOPES=write_discounts,read_discounts,write_functions,read_functions
SHOPIFY_APP_HOST=localhost:8081
PORT=8081
LOG_LEVEL=info

# Role-Based Access Control (RBAC)
# Comma-separated email addresses for each role tier.
# Anyone not listed gets 'admin' if no users are configured, or 'viewer' otherwise.
GCW_ADMIN_EMAILS=admin@example.com
GCW_BUILDER_EMAILS=planner@example.com
GCW_VIEWER_EMAILS=viewer@example.com
